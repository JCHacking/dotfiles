[alias]
    amend = commit --amend
    log-pretty = log --graph --pretty=log

[commit]
    gpgsign = true
    template = ~/.config/git/commit.template.txt

[core]
    autocrlf = input
    editor = nvim
    eol = lf
    excludefile = ~/.config/git/ignore
    pager = delta

[diff]
    algorithm = histogram
    submodule = log
    tool = nvimdiff

[fetch]
    fsckobjects = true
    prune = true
    pruneTags = true

[filter "lfs"]
    clean = git-lfs clean -- %f
    process = git-lfs filter-process
    required = true
    smudge = git-lfs smudge -- %f

[include]
    path = ~/.config/delta/config

[init]
    defaultBranch = main

[log]
    date = iso-local

[merge]
    conflictstyle = zdiff3
    tool = nvimdiff

[pretty]
    log = %Cred%h%Creset - %C(yellow)%ai%Creset -%C(auto)%d%Creset %s %C(bold blue)<%an>%Creset

[pull]
    autoStash = true
    rebase = true

[push]
    autoSetupRemote = true
    followTags = true

[branch]
    sort = -committerdate

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[rerere]
    enabled = true

[receive]
    fsckobjects = true

[status]
    submoduleSummary = true

[submodule]
    recurse = true

[transfer]
    fsckobjects = true

[url "git@github.com:"]
    insteadOf = gh:

[user]
    email = {{git.email}}
    name = {{git.username}}
    signingkey = {{git.email}}
